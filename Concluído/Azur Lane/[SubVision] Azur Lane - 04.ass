Comment: 0,0:01:21.73,0:01:21.73,Opening,,0,0,0,code syl,function cyclic_tag(time,fx1,fx2) local A="" B = 0 C = 0 D = 0 E = 66 count = math.ceil(line.duration/time) D = {fx1,fx2} for i = 1, count do C = i if fx1 and fx2 then if  C%2 ==0 then B = D[1] else B = D[2] end end A = A .."\\t(" ..(i-1)*time+E.. "," ..i*time+E.. ",\\" ..B..")".."" end return A end; temp = {}; function set_temp(ref,val) temp[ref] = val; return val; end
